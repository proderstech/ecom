# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Belgravia Spirits API"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALLOWED_HOSTS='["http://localhost:5173", "http://localhost:3000"]'
API_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=root
DB_PASS=
DATABASE_URL=mysql+aiomysql://root:@127.0.0.1:3306/ecommerce

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=another-different-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ── Email ─────────────────────────────────────────────────────────────────────
MAIL_USERNAME=hello@belgraviasprits.co.uk
MAIL_PASSWORD=your-email-password
MAIL_FROM=hello@belgraviasprits.co.uk
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME="Belgravia Spirits"

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
